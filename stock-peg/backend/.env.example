# ============ 服务器配置 ============
# 服务器监听地址 (0.0.0.0 表示所有网卡)
SERVER_HOST=0.0.0.0

# 服务器端口 (前端需要与此端口保持一致)
# 修改此端口后，需要同步修改 frontend/.env 中的端口配置
SERVER_PORT=8000

# 调试模式
DEBUG=True

# ============ Tushare数据源配置 ============
# Tushare Token (获取财务数据)
# 获取地址: https://tushare.pro/register
TUSHARE_TOKEN=your_tushare_token_here

# ============ AI服务配置 ============
# OpenAI API Key (AI分析)
# OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (Claude AI分析)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 智谱AI配置
# 获取地址: https://open.bigmodel.cn/
AI_DEFAULT_PROVIDER=zhipu
AI_DEFAULT_MODEL=glm-4.7
ZHIPU_API_KEY=your_zhipu_api_key_here

# ============ 美股数据源配置 ============
# 由于 Yahoo Finance API 在中国大陆不可用，请使用以下替代方案：
# 优先级：alphavantage > finnhub > yahoo

# 方案1: Alpha Vantage (推荐)
# 免费 API Key，每分钟5次请求，每天500次
# 获取地址: https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=your_alphavantage_api_key_here

# 方案2: Finnhub (备用)
# 免费 API Key，每分钟60次请求
# 获取地址: https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key_here

# 数据源选择: alphavantage / finnhub / yahoo
US_STOCK_DATA_SOURCE=alphavantage

# ============ 飞书机器人配置 ============
# 飞书应用 ID (从飞书开放平台获取)
FEISHU_APP_ID=your_feishu_app_id_here

# 飞书应用 Secret (从飞书开放平台获取)
FEISHU_APP_SECRET=your_feishu_app_secret_here

# 飞书加密 Key (用于签名验证，可选)
FEISHU_ENCRYPT_KEY=your_feishu_encrypt_key_here

# 飞书验证 Token (用于验证请求来源，可选)
FEISHU_VERIFICATION_TOKEN=your_feishu_verification_token_here

# ============ 配置说明 ============
# 1. 修改 SERVER_PORT 后，需要同步修改 frontend/.env 中的端口
# 2. 所有 API Key 都需要替换为自己的真实密钥
# 3. 修改配置后需要重启服务才能生效


