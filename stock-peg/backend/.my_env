# ============ 服务器配置 ============
# 服务器监听地址 (0.0.0.0 表示所有网卡)
SERVER_HOST=0.0.0.0

# 服务器端口 (前端需要与此端口保持一致)
# 修改此端口后，需要同步修改 frontend/.env 中的端口配置
SERVER_PORT=8000

# 调试模式
DEBUG=True

# 飞书机器人配置
FEISHU_APP_ID=cli_a93c48cba4b8dbef
FEISHU_APP_SECRET=hMYR8zxHuuXdtIE0wEt1tfZd3I7lgCoE


# ============ Tushare数据源配置 ============
# Tushare Token (获取财务数据)
# 获取地址: https://tushare.pro/register
TUSHARE_TOKEN=6f9cc54a4305c049b0666865c817e7a8f76baf810139ee2832891cd5

# ============ AI服务配置 ============
# OpenAI API Key (AI分析)
# OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (Claude AI分析)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 智谱AI配置
# 获取地址: https://open.bigmodel.cn/
AI_DEFAULT_PROVIDER=zhipu
AI_DEFAULT_MODEL=glm-4.7
ZHIPU_API_KEY=0c92300f71ac4c4587aa4e9613c6db9c.ki7cJdHfHaB0YK0m

# ============ 美股数据源配置 ============
# 由于 Yahoo Finance API 在中国大陆不可用，请使用以下替代方案：
# 优先级：alphavantage > finnhub > yahoo

# 方案1: Alpha Vantage (推荐)
# 免费 API Key，每分钟5次请求，每天500次
# 获取地址: https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=35RMMEEL1T2IE9R9

# 方案2: Finnhub (备用)
# 免费 API Key，每分钟60次请求
# 获取地址: https://finnhub.io/register
FINNHUB_API_KEY=d6kr99pr01qmopd1qts0d6kr99pr01qmopd1qtsg

# 数据源选择: alphavantage / finnhub / yahoo
US_STOCK_DATA_SOURCE=alphavantage

# ============ 配置说明 ============
# 1. 修改 SERVER_PORT 后，需要同步修改 frontend/.env 中的端口
# 2. 所有 API Key 都需要替换为自己的真实密钥
# 3. 修改配置后需要重启服务才能生效
