.image {
  width: 100%;
  height: 360rpx;
}
.page-body-info {
  display: flex;
  box-sizing: border-box;
  padding: 30rpx;
  height: 420rpx;
  border-top: 1rpx solid #D9D9D9;
  border-bottom: 1rpx solid #D9D9D9;
  align-items: center;
  justify-content: center;
}
.split {
  border: 1px solid grey;
}

view.sub_case {
  width: 80%;
}

button.sub_btn {
  background: gainsboro;
  border-bottom: #D9D9D9;
  border-bottom-width: 1rpx;
}

.io_area {
  display: flex;
  height: 50rpx;
  width: 100%;
  border-width: 1rpx;
  border-color: blue;
}

.fileType-item {
  width: 160rpx;
  height: min-content;
}
