<import src="../../../common/head.ttml" />
<import src="../../../common/foot.ttml" />

<view class="container">
  <template is="head" data="{{title: 'choose/previewImage'}}" />
  <view class="page-body">
    <form>
      <view class="page-section">
        <view class="page-section-title">
          <text>saveImageToPhotosAlbum\nreference page/API/pages/download-file</text>
        </view>
        <view class="weui-cells weui-cells_after-title">
          <view class="weui-cell weui-cell_input">
            <view class="weui-cell__hd">
              <view class="weui-label">mediaType</view>
            </view>
            <view class="weui-cell__bd">
              <picker range="{{mediaTypes}}" bindchange="mediaTypeChange" value="{{mediaTypeIndex}}" mode="selector">
                <view class="weui-input">{{mediaTypes[mediaTypeIndex]}}</view>
              </picker>
            </view>
          </view>
          <view class="weui-cell weui-cell_input">
            <view class="weui-cell__hd">
              <view class="weui-label">sourceType</view>
            </view>
            <view class="weui-cell__bd">
              <picker range="{{sourceType}}" bindchange="sourceTypeChange" value="{{sourceTypeIndex}}" mode="selector">
                <view class="weui-input">{{sourceType[sourceTypeIndex]}}</view>
              </picker>
            </view>
          </view>

          <view class="weui-cell weui-cell_input">
            <view class="weui-cell__hd">
              <view class="weui-label">count</view>
            </view>
            <view class="weui-cell__bd">
              <picker range="{{count}}" bindchange="countChange" value="{{countIndex}}" mode="selector">
                <view class="weui-input">{{count[countIndex]}}</view>
              </picker>
            </view>
          </view>
          <view class="weui-cell weui-cell_input">
            <view class="weui-cell__hd">
              <view class="weui-label">maxDuration</view>
            </view>
            <view class="weui-cell__bd">
              <picker range="{{duration}}" bindchange="durationChange" value="{{durationIndex}}">
                <view class="weui-input">{{duration[durationIndex]}}</view>
              </picker>
            </view>
          </view>
          <view class="weui-cell weui-cell_input">
            <view class="weui-cell__hd">
              <view class="weui-label">sizeType</view>
            </view>
            <view class="weui-cell__bd">
              <picker range="{{sizeTypes}}" bindchange="sizeTypeChange" value="{{sizeTypeIndex}}" mode="selector">
                <view class="weui-input">{{sizeTypes[sizeTypeIndex]}}</view>
              </picker>
            </view>
          </view>
          <view class="weui-cell weui-cell_input">
            <view class="weui-cell__hd">
              <view class="weui-label">cameraDevice</view>
            </view>
            <view class="weui-cell__bd">
              <picker range="{{cameraDevices}}" bindchange="cameraDeviceChange" value="{{cameraDeviceIndex}}" mode="selector">
                <view class="weui-input">{{cameraDevices[cameraDeviceIndex]}}</view>
              </picker>
            </view>
          </view>
        </view>
        <view class="weui-cells">
          <view class="weui-cell">
            <view class="weui-cell__bd">
              <view class="weui-uploader">
                <view class="weui-uploader__bd">
                  <view class="weui-uploader__files">
                    <block tt:for="{{dataArray}}" tt:for-item="item">
                      <view tt:if="{{item.type == 'image'}}">
                        <image class="weui-uploader__img" src="{{item.tempFilePath}}" data-src="{{item.tempFilePath}}" bindtap="previewImage"></image>
                      </view>
                      <view tt:elif="{{item.type == 'video'}}">
                        <video src="{{item.tempFilePath}}" class="video"></video>
                      </view>
                      <view tt:else> item is nil or error item type, It needs to be image or video </view>
                    </block>
                  </view>
                  <view class="weui-uploader__input-box">
                    <view class="weui-uploader__input" bindtap="chooseMedia"></view>
                  </view>
                </view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </form>
  </view>
  <template is="foot" />
</view>
