@import "/page/PC/common/index.ttss";

.text-box {
  margin-bottom: 24px;
  padding: 10px 0;
  display: flex;
  height: 300px;
  background-color: #eff0f1;
  justify-content: center;
  align-items: center;
  text-align: center;
  font-size: 25px;
  color: #353535;
  line-height: 2em;
  overflow-y: scroll;
}

button {
  margin-right: 32px;
}

button:last-child {
  margin-right: 0;
}