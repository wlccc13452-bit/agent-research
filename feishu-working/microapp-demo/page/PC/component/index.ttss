@import '../common/index.ttss';

.side-left .menu_container {
  /* border-bottom: 1px solid #eee; */
}

.menu_container .title {
  position: relative;
  height     : 54px;
  line-height: 54px;
  font-size  : 16px;
  color      : #1f2329;
  /* text-align : center; */
  font-weight: 500;
  padding-left: 24px;
}

.side-left .menu_container:last-child {
  /* border-bottom: initial; */
}

.side-left::-webkit-scrollbar {
  width: 0;
}

.hr {
  height    : 1px;
  width     : 100%;
  background-color: #bbbfc4;
  opacity   :  0.5;
  overflow  : hidden;
}

.content {
  padding: 32px;
}

.arrow-icon {
  position: absolute;
  width: 12px;
  height: 12px;
  right: 24px;
  top: 50%;
  transform: translateY(-50%) rotate(-90deg) ;
  background-image: url('page/PC/common/component/Menu/resources/arrow.svg');
  background-repeat: no-repeat;
}

.arrow-icon.opened {
  transform: translateY(-50%);
}