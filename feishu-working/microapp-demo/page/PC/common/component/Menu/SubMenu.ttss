.sub-menu {
  /* color: rgba(0, 0, 0, .95); */
}

.sub-menu > .dropdown {
  display: none;
  /* transition: display 1.5s; */
}

.sub-menu > .title {
  position: relative;
  height: 44px;
  line-height: 44px;
  padding-left: 39px;
  font-size: 14px;
  text-transform: capitalize;
}

.sub-menu.active > .dropdown {
  display: block;
}

.sub-menu.active > .title {
  /* color: rgba(0, 0, 0, .35); */
}

.arrow-icon {
  position: absolute;
  width: 0;
  height: 0;
  border: 3.5px solid transparent;
  border-bottom-width: 5px;
  border-top: 5px solid #646a73;
  left: 24px;
  top: 50%;
  transform: translateY(-25%) rotate(-90deg) ;
  transform-origin: 3.5px 2.5px;
}

.arrow-icon.opened {
  transform: translateY(-25%);
}
